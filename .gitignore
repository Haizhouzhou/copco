eyebench/**/*.parquet
eyebench/**/*.pkl
eyebench/**/*.pt
eyebench/**/*.ckpt
eyebench/data/**/*.csv
eyebench/results/**/*.csv
results/official_eyebench_runtime_fix_v1_*/

